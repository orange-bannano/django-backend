# =============================================================================
# Django core
# =============================================================================
DJANGO_SECRET_KEY=LONG_RANDOM_STRING
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,.localhost,[::1]
CSRF_TRUSTED_ORIGINS=https://localhost,http://localhost
SSL=False
HSTS=False
X_FORWARD=False
# =============================================================================
# API & frontend URLs
# =============================================================================
# Leave API_BASE_URL empty when the frontend is served from the same origin as Django.
API_BASE_URL=
# Public site URL (used in OpenAPI / links). No trailing slash.
SITE_BASE_URL=http://localhost:8000
ADMIN_URL=/admin/
DEV_IP=YOUR_IP
# =============================================================================
# MySQL database
# =============================================================================
DB_ENGINE=django.db.backends.mysql
DB_NAME=my_django_db
DB_USER=root
DB_PASSWORD=pass
DB_HOST=127.0.0.1
DB_PORT=3306

# =============================================================================
# Redis cache (sessions, idempotency, rate limiting)
# =============================================================================
REDIS_URL=redis://127.0.0.1:6379/1

# =============================================================================
# Session
# =============================================================================
SESSION_COOKIE_AGE=3600
SESSION_EXPIRE_AT_BROWSER_CLOSE=False
