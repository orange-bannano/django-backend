# Copy to .env and fill in your values:
#   cp .env.example .env

# =============================================================================
# Django core
# =============================================================================
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,.localhost,[::1]
SSL=False
HSTS=False
# =============================================================================
# API & frontend URLs
# =============================================================================
# Leave empty for same-origin (frontend served by Django at SITE_BASE_URL).
API_BASE_URL=
SITE_BASE_URL=http://127.0.0.1:8000
ADMIN_URL=/admin/
DEV_IP='YOUR IP_ADDRESS_HERE'
# =============================================================================
# MySQL database
# =============================================================================
DB_ENGINE=django.db.backends.mysql
DB_NAME=my_django_db
DB_USER=root
DB_PASSWORD=your-password-here
DB_HOST=127.0.0.1
DB_PORT=3306

# =============================================================================
# Redis cache
# =============================================================================
REDIS_URL=redis://127.0.0.1:6379/1

# =============================================================================
# Session
# =============================================================================
SESSION_COOKIE_AGE=3600
SESSION_EXPIRE_AT_BROWSER_CLOSE=False
